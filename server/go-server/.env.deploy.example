# Copy to .env.deploy and fill in. Used by scripts/deploy-from-local.sh
# Do not commit .env.deploy (add to .gitignore if needed).
#
# Image naming: we build and push as DOCKER_REGISTRY_IMAGE:TAG
# (same as: docker tag local-image:tagname new-repo:tagname && docker push new-repo:tagname)

# Full image name without tag (registry/repo). Tag comes from VERSION or script argument.
DOCKER_REGISTRY_IMAGE=docker.io/myuser/ludi-server

# Prod server SSH
PROD_HOST=my.server.com
PROD_USER=deploy
# Paths on the server (use deploy_test.sh and deploy_prod.sh)
PROD_APP_DIR_TEST=placeholder/deploy/test
PROD_APP_DIR_PROD=placeholder/deploy/prod
